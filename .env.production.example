APP_ENV=production
GENERATION_PROFILE=production
ENABLE_PROVIDER_FALLBACK=false

# OpenRouter is used for real vision/text generation, not for voice/video bytes.
VISION_PROVIDER=openrouter
TEXT_PROVIDER=openrouter
OPENROUTER_API_KEY=
OPENROUTER_VISION_MODEL=
OPENROUTER_TEXT_MODEL=

# Choose one real TTS provider.
TTS_PROVIDER=elevenlabs
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=
ELEVENLABS_MODEL_ID=eleven_multilingual_v2

# Alternative:
# TTS_PROVIDER=yandex_speechkit
# YANDEX_SPEECHKIT_API_KEY=
# YANDEX_SPEECHKIT_FOLDER_ID=
# YANDEX_SPEECHKIT_VOICE=alena

# Final assembly provider. In ai_video mode this is used only for stitching/subtitles/CTA fallback workflows.
VIDEO_MODE=ai_video
VIDEO_PROVIDER=creatomate
CREATOMATE_API_KEY=
CREATOMATE_TEMPLATE_9_16=
CREATOMATE_TEMPLATE_1_1=

# AI-video scene provider. Production guardrails reject mock providers.
AI_VIDEO_PROVIDER=kling
AI_VIDEO_FALLBACK_PROVIDER=mock
AI_VIDEO_DEFAULT_DURATION_SEC=6
AI_VIDEO_DEFAULT_ASPECT_RATIO=9:16
AI_VIDEO_SCENES_COUNT=4
KLING_API_KEY=
RUNWAY_API_KEY=
