APP_NAME=Kunzhutik Content Factory
APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8000
# Local development:
APP_BASE_URL=http://localhost:8000
# Production Telegram WebApp requires HTTPS. Example:
# PUBLIC_DOMAIN=orders.example.com
# APP_BASE_URL=https://orders.example.com
# TELEGRAM_APPROVAL_BASE_URL=https://orders.example.com
PUBLIC_DOMAIN=localhost
LOG_LEVEL=INFO

POSTGRES_DB=kunzhutik
POSTGRES_USER=kunzhutik
POSTGRES_PASSWORD=kunzhutik
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
DATABASE_URL=postgresql+psycopg://kunzhutik:kunzhutik@postgres:5432/kunzhutik

REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

S3_ENDPOINT_URL=http://minio:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET=kunzhutik-media
S3_REGION=us-east-1
S3_SECURE=false

TELEGRAM_BOT_TOKEN=
TELEGRAM_APPROVAL_CHAT_ID=
TELEGRAM_APPROVAL_BASE_URL=
TELEGRAM_OPEN_ACCESS=false
TELEGRAM_ALLOWED_USER_IDS=

DASHBOARD_SECRET_KEY=change-me-dashboard-secret
DASHBOARD_COOKIE_NAME=kunzhutik_dashboard_session
DASHBOARD_BOOTSTRAP_USERNAME=admin
DASHBOARD_BOOTSTRAP_PASSWORD=change-me
DASHBOARD_BOOTSTRAP_ROLE=admin

# mock keeps local development free of external API calls.
# Set VISION_ANALYSIS_PROVIDER=openai and OPENAI_API_KEY for real dish photo analysis.
VISION_ANALYSIS_PROVIDER=mock
OPENAI_API_KEY=
OPENAI_VISION_MODEL=gpt-4.1-mini
OPENAI_VISION_DETAIL=low
OPENAI_VISION_TIMEOUT_SECONDS=45
OPENAI_VISION_MAX_OUTPUT_TOKENS=900

DEFAULT_PROJECT_SLUG=kunzhutik-food
DEFAULT_PROJECT_NAME=Kunzhutik Food Lab
DEFAULT_CHARACTER_NAME=Кунжутик
