APP_NAME=Kunzhutik Content Factory
APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8000
# Local development:
APP_BASE_URL=http://localhost:8000
# Production Telegram WebApp requires HTTPS. Example:
# PUBLIC_DOMAIN=orders.example.com
# APP_BASE_URL=https://orders.example.com
# TELEGRAM_APPROVAL_BASE_URL=https://orders.example.com
PUBLIC_DOMAIN=localhost
LOG_LEVEL=INFO

POSTGRES_DB=kunzhutik
POSTGRES_USER=kunzhutik
POSTGRES_PASSWORD=kunzhutik
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
DATABASE_URL=postgresql+psycopg://kunzhutik:kunzhutik@postgres:5432/kunzhutik

REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

S3_ENDPOINT_URL=http://minio:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET=kunzhutik-media
S3_REGION=us-east-1
S3_SECURE=false

TELEGRAM_BOT_TOKEN=
TELEGRAM_APPROVAL_CHAT_ID=
TELEGRAM_APPROVAL_BASE_URL=
TELEGRAM_OPEN_ACCESS=false
TELEGRAM_ALLOWED_USER_IDS=

DASHBOARD_SECRET_KEY=change-me-dashboard-secret
DASHBOARD_COOKIE_NAME=kunzhutik_dashboard_session
DASHBOARD_BOOTSTRAP_USERNAME=admin
DASHBOARD_BOOTSTRAP_PASSWORD=change-me
DASHBOARD_BOOTSTRAP_ROLE=admin

# Provider fallback keeps local development and demos resilient if external APIs fail.
GENERATION_PROFILE=local
ENABLE_PROVIDER_FALLBACK=true

# Vision provider. Use VISION_PROVIDER=openrouter for real dish photo analysis.
VISION_PROVIDER=mock
OPENROUTER_API_KEY=
OPENROUTER_VISION_MODEL=
OPENROUTER_TEXT_MODEL=
OPENROUTER_TIMEOUT_SECONDS=60

# Text provider. Use TEXT_PROVIDER=openrouter for persona copy generation.
TEXT_PROVIDER=mock

# Legacy experimental OpenAI vision settings. Prefer VISION_PROVIDER above.
VISION_ANALYSIS_PROVIDER=mock
OPENAI_API_KEY=
OPENAI_VISION_MODEL=gpt-4.1-mini
OPENAI_VISION_DETAIL=low
OPENAI_VISION_TIMEOUT_SECONDS=45
OPENAI_VISION_MAX_OUTPUT_TOKENS=900

# TTS provider. mock uses local espeak-ng fallback.
TTS_PROVIDER=mock
TTS_TIMEOUT_SECONDS=60

ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=
ELEVENLABS_MODEL_ID=eleven_multilingual_v2

YANDEX_SPEECHKIT_API_KEY=
YANDEX_SPEECHKIT_FOLDER_ID=
YANDEX_SPEECHKIT_VOICE=alena

# Video render provider. ffmpeg keeps local rendering self-contained.
VIDEO_PROVIDER=ffmpeg
VIDEO_RENDER_TIMEOUT_SECONDS=120
CREATOMATE_API_KEY=
CREATOMATE_TEMPLATE_9_16=
CREATOMATE_TEMPLATE_1_1=

# Publishing provider. mock is safe locally; vk posts text to a VK group; manual creates operator packages.
PUBLISHER_PROVIDER=mock
PUBLISHER_TIMEOUT_SECONDS=60
VK_ACCESS_TOKEN=
VK_GROUP_ID=
VK_API_VERSION=5.199

DEFAULT_PROJECT_SLUG=kunzhutik-food
DEFAULT_PROJECT_NAME=Kunzhutik Food Lab
DEFAULT_CHARACTER_NAME=Кунжутик
